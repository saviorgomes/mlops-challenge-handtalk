# Exemplo de arquivo .htpasswd para autenticação Basic Auth no nginx.
# Gere o seu com: htpasswd -c nginx/.htpasswd <usuario>
# Ou via Docker:  docker run --rm httpd:2.4-alpine htpasswd -nbB admin <senha>
#
# O arquivo real (nginx/.htpasswd) está no .gitignore — nunca o commite.
admin:$apr1$XXXXXXXX$XXXXXXXXXXXXXXXXXXXXXXX
